# ============================================================
# NEXORA — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/nexora?sslmode=require"
DIRECT_URL="postgresql://user:password@host/nexora?sslmode=require"

# Auth (NextAuth v5)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Supabase Storage
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="nexora-files"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Nexora"

# Email (Resend - optional for invitations)
RESEND_API_KEY="re_your_key"
EMAIL_FROM="noreply@nexora.app"

# Socket.IO
NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"
